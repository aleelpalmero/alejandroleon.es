---
import { getImage } from "astro:assets"
import NextJS from "./icons/NextJS.astro"
import Tailwind from "./icons/Tailwind.astro"
import Wordpress from "./icons/Wordpress.astro"
import Woocommerce from "./icons/Woocommerce.astro"
import Link from "./icons/Link.astro"
import LinkButton from "./LinkButton.astro"
import abtImage from "@/assets/projects/abt.webp"
import fabeImage from "@/assets/projects/fabe.webp"
import islabImage from "@/assets/projects/islab.webp"
 
const TAGS = {
  NEXT: {
    name: "Next.js",
    class: "bg-black text-white",
    icon: NextJS,
  },
  TAILWIND: {
    name: "Tailwind CSS",
    class: "bg-[#003159] text-white",
    icon: Tailwind,
  },
  WORDPRESS: {
    name: "Wordpress",
    class: "bg-[#003159] text-white",
    icon: Wordpress,
  },
  WOOCOMMERCE: {
    name: "Woocommerce",
    class: "bg-[#7e53b2] text-white",
    icon: Woocommerce,
  },
}
const PROJECTS = [
  {
    title: "isLAB - Agencia de diseño",
    description:
      "Desde la concepción hasta la implementación, creamos soluciones digitales únicas que superan expectativas. Nuestro equipo experto utiliza tecnologías de vanguardia para desarrollar interfaces intuitivas, diseños atractivos y funcionalidades innovadoras. Nos comprometemos a transformar visiones en experiencias digitales memorables.",
    link: "https://islab.es",
    image: islabImage,
    tags: [TAGS.WORDPRESS],
  },
  {
    title: "AB Tenerife",
    description:
      "Página web de la Asociación de Bartenders de Tenerife, con Woocommerce para permitir a los usuarios asociarse totalmente online, con blog y todo tipo de información de campeonatos, eventos e historia.",
    link: "https://abtenerife.com",
    image: abtImage,
    tags: [TAGS.WORDPRESS, TAGS.WOOCOMMERCE],
  },
  {
    title: "Federación de Asociaciones de Bartender de España",
    description:
      "Renovación completa de la web, mucho más intuitiva, optimizada y responsive, donde se podrán consultar los campeonatos, históricos, próximos eventos, suscribirse al calendario y sincronizarlo con los de tu teléfono o PC, entre otras cosas...",
    link: "https://fabebarmans.com",
    image: fabeImage,
    tags: [TAGS.WORDPRESS],
  }, 
]

const optimizedProjects = await Promise.all(
  PROJECTS.map(async (project) => ({
    ...project,
    optimizedImage: await getImage({
      src: project.image,
      width: 960,
      format: "webp",
      quality: 72,
    }),
  })),
)
---

<div class="flex flex-col gap-y-16">
  {
    optimizedProjects.map(({ optimizedImage, title, description, tags, link }, index) => (
    <article class="flex flex-col space-x-0 space-y-8 md:flex-row md:space-x-8 md:space-y-0">
  <div class="w-full md:w-1/2">
    <div class="rounded-xl shadow-xl lg:border lg:border-gray-800">
      <img
        src={optimizedImage.src}
        alt={`Captura del proyecto ${title}`}
        width={optimizedImage.attributes.width}
        height={optimizedImage.attributes.height}
        loading="eager"
        fetchpriority={index === 0 ? "high" : "auto"}
        class="block w-full h-auto rounded-xl"
      />
    </div>
  </div>

  <div class="w-full md:w-1/2 md:max-w-lg">
    <h3 class="text-2xl font-bold text-gray-800 dark:text-gray-100">
      {title}
    </h3>
    <div class="flex flex-wrap mt-2">
      <ul class="flex flex-row mb-2 gap-x-2">
          {tags.map((tag) => (
            <li>
              <span
                class={`flex gap-x-2 rounded-full text-xs ${tag.class} py-1 px-2 `}
              >
                <tag.icon class="size-4" />
                {tag.name}
              </span>
            </li>
          ))}
        </ul>

      <div class="mt-2 text-gray-700 dark:text-gray-400">{description}</div>
      <footer class="flex items-end justify-start mt-4 gap-x-4">

          {link && (
            <LinkButton href={link}>
              <Link class="size-4" />
              Visitar
            </LinkButton>
          )}
        </footer>
    </div>
  </div>
</article>
    ))
  }
</div>



